# claudegpt configuration
# Copy this file to `.env` and fill in the values for the backend you want to use.

# ============================================================
# Backend selection: "azure" | "openai" | "codex"
# ============================================================
CLAUDEGPT_PROVIDER=azure

# ============================================================
# Azure OpenAI (provider=azure)
# ============================================================
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_RESPONSES_API_VERSION=preview

# Deployment names (must already exist in your Azure resource)
AZURE_OPENAI_CHAT_DEPLOYMENT_FULL=gpt-5-5
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-54-mini
AZURE_OPENAI_CHAT_DEPLOYMENT_NANO=gpt-54-nano

# ============================================================
# OpenAI direct (provider=openai)
# ============================================================
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# CLAUDEGPT_OPENAI_OPUS=gpt-5.5
# CLAUDEGPT_OPENAI_SONNET=gpt-5.4-mini
# CLAUDEGPT_OPENAI_HAIKU=gpt-5.4-mini

# ============================================================
# Codex (provider=codex) — uses ChatGPT subscription via ~/.codex/auth.json
# ============================================================
# CLAUDEGPT_CODEX_AUTH=/Users/you/.codex/auth.json
# CLAUDEGPT_CODEX_OPUS=gpt-5.5
# CLAUDEGPT_CODEX_SONNET=gpt-5.4-mini
# CLAUDEGPT_CODEX_HAIKU=gpt-5.4-mini

# ============================================================
# Reasoning effort per Claude model tier (low | medium | high)
# Tools-bearing turns are auto-shifted to CLAUDEGPT_TOOLS_REASONING.
# ============================================================
CLAUDEGPT_REASONING_OPUS=medium
CLAUDEGPT_REASONING_SONNET=medium
CLAUDEGPT_REASONING_HAIKU=medium
CLAUDEGPT_TOOLS_REASONING=low

# ============================================================
# Server bind (rarely needs changing)
# ============================================================
# CLAUDEGPT_HOST=127.0.0.1
# CLAUDEGPT_PORT=3210
