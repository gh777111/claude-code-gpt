#!/usr/bin/env bash
# claudegpt — launch Claude Code against a non-Anthropic backend
# (provider chosen via CLAUDEGPT_PROVIDER: azure | openai | codex)
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")" && pwd)"
HOST="${CLAUDEGPT_HOST:-127.0.0.1}"
PORT="${CLAUDEGPT_PORT:-3210}"
PIDFILE="${TMPDIR:-/tmp}/claudegpt-${PORT}.pid"
LOGFILE="${TMPDIR:-/tmp}/claudegpt-${PORT}.log"

UV_BIN="${UV_BIN:-}"
if [[ -z "$UV_BIN" ]]; then
  if command -v uv >/dev/null 2>&1; then
    UV_BIN="$(command -v uv)"
  else
    echo "[claudegpt] uv not found in PATH. Install: https://docs.astral.sh/uv/" >&2
    echo "                or set UV_BIN to the uv binary." >&2
    exit 1
  fi
fi

# Pull launcher-level CLAUDEGPT_* keys from .env files so settings work regardless
# of which shell rc the calling environment loaded. Existing env wins.
for envfile in "$HOME/.claude/.env" "$ROOT/.env"; do
  [[ -f "$envfile" ]] || continue
  while IFS='=' read -r key val; do
    [[ "$key" == CLAUDEGPT_* ]] || continue
    [[ -z "${!key:-}" ]] || continue
    val="${val%\"}"; val="${val#\"}"; val="${val%\'}"; val="${val#\'}"
    export "$key=$val"
  done < <(grep -E '^CLAUDEGPT_[A-Z_]+=' "$envfile" 2>/dev/null || true)
done

# Pass cwd through to the proxy so traces can be grouped per project.
export CLAUDEGPT_CWD="$(pwd)"

# Capture --effort flag from claude args and translate into proxy reasoning envs.
# Claude Code does NOT forward `thinking` to non-Anthropic backends, so we apply
# the effort here instead.  Mapping: low/medium/high passthrough; xhigh/max → high.
EFFORT_FLAG=""
prev_arg=""
for a in "$@"; do
  if [[ "$prev_arg" == "--effort" ]]; then
    EFFORT_FLAG="$a"; break
  elif [[ "$a" == --effort=* ]]; then
    EFFORT_FLAG="${a#--effort=}"; break
  fi
  prev_arg="$a"
done
if [[ -n "$EFFORT_FLAG" ]]; then
  case "$EFFORT_FLAG" in
    low|medium|high) eff="$EFFORT_FLAG" ;;
    xhigh|max)       eff="high" ;;
    *) eff="" ;;
  esac
  if [[ -n "$eff" ]]; then
    export CLAUDEGPT_TOOLS_REASONING="$eff"
    export CLAUDEGPT_REASONING_OPUS="$eff"
    export CLAUDEGPT_REASONING_SONNET="$eff"
    export CLAUDEGPT_REASONING_HAIKU="$eff"
    EFFORT_TAG_FILE="${TMPDIR:-/tmp}/claudegpt-${PORT}.effort"
    if [[ -f "$PIDFILE" ]] && [[ "$(cat "$EFFORT_TAG_FILE" 2>/dev/null || echo)" != "$eff" ]]; then
      # running proxy was started with a different effort — restart so envs apply
      old_pid="$(cat "$PIDFILE" 2>/dev/null || true)"
      [[ -n "${old_pid:-}" ]] && kill "$old_pid" 2>/dev/null || true
      rm -f "$PIDFILE"
      sleep 0.3
    fi
    echo "$eff" > "$EFFORT_TAG_FILE"
  fi
fi

started_here=0
cleanup() {
  if [[ "$started_here" == "1" && -f "$PIDFILE" ]]; then
    pid="$(cat "$PIDFILE" 2>/dev/null || true)"
    if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
    fi
    rm -f "$PIDFILE"
  fi
}
trap cleanup EXIT INT TERM

if [[ ! -f "$ROOT/.env" && ! -f "$HOME/.claude/.env" ]]; then
  echo "[claudegpt] no .env yet — running first-run setup" >&2
  ( cd "$ROOT" && python3 setup.py ) || exit 1
fi

if curl -fsS "http://${HOST}:${PORT}/healthz" >/dev/null 2>&1; then
  :
else
  echo "[claudegpt] starting proxy on ${HOST}:${PORT}…" >&2
  cd "$ROOT"
  CLAUDEGPT_HOST="$HOST" CLAUDEGPT_PORT="$PORT" \
    "$UV_BIN" run --quiet python server.py \
    >"$LOGFILE" 2>&1 &
  echo $! >"$PIDFILE"
  started_here=1

  for _ in $(seq 1 120); do
    if curl -fsS "http://${HOST}:${PORT}/healthz" >/dev/null 2>&1; then
      break
    fi
    pid="$(cat "$PIDFILE" 2>/dev/null || true)"
    if [[ -z "${pid:-}" ]] || ! kill -0 "$pid" 2>/dev/null; then
      echo "[claudegpt] proxy died; check log: $LOGFILE" >&2
      tail -n 40 "$LOGFILE" >&2 || true
      exit 1
    fi
    sleep 0.5
  done

  if ! curl -fsS "http://${HOST}:${PORT}/healthz" >/dev/null 2>&1; then
    echo "[claudegpt] proxy did not become healthy in time; log: $LOGFILE" >&2
    tail -n 40 "$LOGFILE" >&2 || true
    exit 1
  fi
fi

export ANTHROPIC_BASE_URL="http://${HOST}:${PORT}"
export ANTHROPIC_AUTH_TOKEN="claudegpt"
unset ANTHROPIC_API_KEY || true
export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_DEFAULT_OPUS_MODEL:-claude-opus-4-7}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_DEFAULT_SONNET_MODEL:-claude-sonnet-4-6}"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_DEFAULT_HAIKU_MODEL:-claude-haiku-4-5}"
unset ANTHROPIC_MODEL || true

# 비용/지연 최소화 — 부수적인 모델 호출(대화 요약, autocompact 결정 등) 끔
export DISABLE_NON_ESSENTIAL_MODEL_CALLS="${DISABLE_NON_ESSENTIAL_MODEL_CALLS:-1}"
export DISABLE_AUTOCOMPACT="${DISABLE_AUTOCOMPACT:-1}"
export DISABLE_TELEMETRY="${DISABLE_TELEMETRY:-1}"
export MAX_THINKING_TOKENS="${MAX_THINKING_TOKENS:-0}"

# 글로벌 설정(전역 CLAUDE.md / agents / skills / MCP) 격리 — 토큰 절감
# 프로젝트 ./CLAUDE.md 는 그대로 사용됨 (cwd 변경 안 함)
CLAUDEGPT_GLOBAL_ISOLATE="${CLAUDEGPT_GLOBAL_ISOLATE:-1}"
if [[ "$CLAUDEGPT_GLOBAL_ISOLATE" == "1" ]]; then
  CLEAN_CONFIG="${CLAUDEGPT_CLEAN_CONFIG_DIR:-/tmp/claudegpt-clean-config}"
  mkdir -p "$CLEAN_CONFIG"
  if [[ ! -f "$CLEAN_CONFIG/settings.json" ]]; then
    cat > "$CLEAN_CONFIG/settings.json" <<'JSON'
{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Task",
      "TodoWrite",
      "WebFetch",
      "NotebookEdit"
    ]
  }
}
JSON
  fi
  export CLAUDE_CONFIG_DIR="$CLEAN_CONFIG"
fi

exec claude "$@"
